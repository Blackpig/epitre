{
    "name": "blackpig-creatif/epitre",
    "description": "A filamentPHP plugin to manage email templates for Mailables",
    "keywords": [
        "BlackpigCreatif",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "epitre"
    ],
    "homepage": "https://github.com/blackpig/epitre",
    "support": {
        "issues": "https://github.com/blackpig/epitre/issues",
        "source": "https://github.com/blackpig/epitre"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Blackpig",
            "email": "stuart@blackpig.eu",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "filament/filament": "^5.0",
        "lara-zeus/spatie-translatable": "^2.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "filament/blueprint": "^2.1",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.3",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "rector/rector": "^2.0",
        "spatie/laravel-ray": "^1.26"
    },
    "autoload": {
        "psr-4": {
            "BlackpigCreatif\\Epitre\\": "src/",
            "BlackpigCreatif\\Epitre\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BlackpigCreatif\\Epitre\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "BlackpigCreatif\\Epitre\\EpitreServiceProvider"
            ],
            "aliases": {
                "Epitre": "BlackpigCreatif\\Epitre\\Facades\\Epitre"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [{
        "name": "filament",
        "type": "composer",
        "url": "https://packages.filamentphp.com/composer"
    }]
}
